{
  "name": "openclaw-token",
  "version": "0.8.0",
  "description": "CLI client for OpenClaw Token proxy — manage credits, provision API keys, integrate with OpenClaw fallback chain",
  "type": "module",
  "bin": {
    "openclaw-token": "./dist/bin/openclaw-token.js"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./sdk": "./dist/src/sdk.js"
  },
  "typesVersions": {
    "*": {
      "sdk": [
        "./dist/src/sdk.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/openclaw-token.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:contract:mock": "vitest run --config vitest.contract.config.ts",
    "test:contract:real": "CONTRACT_TEST_BASE_URL=http://localhost:3000 vitest run --config vitest.contract.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "token",
    "cli",
    "api-key",
    "credits"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "axios": "^1.13.0",
    "chalk": "^5.6.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "which": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/which": "^3.0.4",
    "execa": "^9.6.1",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  }
}
