{
  "name": "openclaw-token",
  "version": "0.5.0",
  "description": "CLI client for OpenClaw Token proxy — manage credits, provision API keys, integrate with OpenClaw fallback chain",
  "type": "module",
  "bin": {
    "openclaw-token": "./dist/bin/openclaw-token.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/openclaw-token.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:contract:mock": "vitest run --config vitest.contract.config.ts",
    "test:contract:real": "CONTRACT_TEST_BASE_URL=http://localhost:3000 vitest run --config vitest.contract.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "token",
    "cli",
    "api-key",
    "credits"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "inquirer": "^9.3.0",
    "ora": "^8.1.0",
    "which": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/which": "^3.0.4",
    "execa": "^8.0.1",
    "tsup": "^8.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
