      "new_pitfalls": [
        {
          "id": "P-CLI-001",
          "tag": "cli/mock",
          "title": "sk-mgmt- token format requires strict hex UUID",
          "description": "Do not use mnemonic chars like 'demo' in management key — mock auth validation will fail.",
          "mitigation": "S3 implementation plan must specify exact token format and provide conforming fixture values."
        },
        {
          "id": "P-CLI-002",
          "tag": "cli/axios",
          "title": "Axios request interceptors execute in reverse registration order (LIFO)",
          "description": "Setting auth headers in a separate interceptor registered after the mock adapter interceptor means the auth header is set before mock adapter runs, causing it to be missing.",
          "mitigation": "Set auth headers in the same interceptor that reads them, or explicitly account for LIFO ordering."
        },
        {
          "id": "P-CLI-003",
          "tag": "cli/testing",
          "title": "Mock handlers must use router-injected store, not module-level singleton",
          "description": "Module-level singleton store breaks test isolation — each test suite shares state across tests.",
          "mitigation": "Pass store as a parameter to mock handler factory functions; reset per test in beforeEach."
        },
        {
          "id": "P-CLI-004",
          "tag": "cli/architecture",
          "title": "工具函式跨模組重複定義",
          "description": "Greenfield CLI 專案容易在多個模組中各自定義相同工具函式，S4 完成後 S5 才發現。",
          "mitigation": "S3 實作計畫中對每個 utils 函式明確標記 owner 模組；S5 Code Review 必須掃描同名 export。"
